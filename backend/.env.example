# Copia este archivo a .env y completa la clave si dispones de una.
# Sin GEMINI_API_KEY la app funciona igual: la categorización usa el fallback
# por palabras clave y el chat degrada con un mensaje claro.

# Clave del tier gratis de Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo a usar (por defecto gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Moneda única de la demo (ISO 4217)
DEFAULT_CURRENCY=COP

# Ruta del archivo SQLite (por defecto backend/data/finanzas.db)
# DB_PATH=data/finanzas.db
