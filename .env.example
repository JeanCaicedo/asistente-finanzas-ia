# Copia este archivo a .env y completa la clave del proveedor que uses.

# Proveedor LLM activo: "gemini" o "claude"
LLM_PROVIDER=gemini

# --- Gemini (gratis, sin tarjeta) ---
# Consíguela en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional: modelo a usar (por defecto gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# --- Claude / Anthropic (de pago por uso) ---
# Consíguela en https://console.anthropic.com  (requiere cargar saldo)
# ANTHROPIC_API_KEY=sk-ant-...
# Opcional: modelo a usar (por defecto claude-sonnet-5)
# CLAUDE_MODEL=claude-sonnet-5
